---
import Logo from '../components/Logo.astro';
interface Props {
  titulo: string;
  subtitulo?: string;
}
import { url } from '../lib/url';
const { titulo, subtitulo } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const nav = [
  { href: '/', label: 'Visão Geral' },
  { href: '/imoveis', label: 'Imóveis' },
  { href: '/alertas', label: 'Alertas' },
  { href: '/centros-custo', label: 'Centros de Custo' },
  { href: '/criterios', label: 'Critérios' },
];
const isActive = (href: string) => {
  const target = url(href).replace(/\/$/, '') || '/';
  return href === '/' ? path === target : path.startsWith(target);
};
---

<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap"
      rel="stylesheet"
    />
    <title>{titulo} · Lumo Properties</title>
    <meta name="description" content="Dashboard operacional da Lumo Properties — operação imobiliária na região Vidigueira / Beja." />
  </head>
  <body class="min-h-screen bg-cream text-ink font-sans antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="hidden md:flex w-64 flex-col bg-lumo-700 text-cream">
        <a href={url('/')} class="block px-6 py-6 border-b border-lumo-600">
          <Logo markColor="#dbf090" textColor="#fffaf3" subColor="#dbf090" size={34} />
        </a>
        <nav class="flex-1 px-3 py-4 space-y-1">
          {nav.map((item) => (
            <a
              href={url(item.href)}
              class={`block rounded-lg px-3 py-2 text-sm font-medium transition ${
                isActive(item.href)
                  ? 'bg-lime-300 text-lumo-800'
                  : 'text-cream/70 hover:bg-lumo-600 hover:text-cream'
              }`}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="px-6 py-4 border-t border-lumo-600 text-[11px] text-lime-300/70">
          MVP · demonstração para financiamento
        </div>
      </aside>

      <!-- Main -->
      <div class="flex-1 flex flex-col min-w-0">
        <!-- Top bar (mobile nav) -->
        <header class="md:hidden bg-lumo-700 text-cream px-4 py-3 flex items-center justify-between gap-3">
          <a href={url('/')}><Logo markColor="#dbf090" textColor="#fffaf3" subColor="#dbf090" size={26} /></a>
          <nav class="flex gap-2 overflow-x-auto text-xs">
            {nav.map((item) => (
              <a href={url(item.href)} class={`whitespace-nowrap px-2 py-1 rounded ${isActive(item.href) ? 'bg-lime-300 text-lumo-800' : 'text-cream/70'}`}>{item.label}</a>
            ))}
          </nav>
        </header>

        <main class="flex-1 px-4 md:px-8 py-6 md:py-8 max-w-6xl w-full">
          <div class="mb-6">
            <h1 class="text-2xl md:text-3xl font-bold text-lumo-900">{titulo}</h1>
            {subtitulo && <p class="text-lumo-600 mt-1">{subtitulo}</p>}
          </div>
          <slot />
        </main>

        <footer class="px-4 md:px-8 py-4 text-[11px] text-lumo-700/60 border-t border-lumo-100">
          Lumo Properties — dados reais de anúncios públicos (imovirtual.com). Sem integração real de WhatsApp; faturas são documentos de demonstração.
        </footer>
      </div>
    </div>
  </body>
</html>
