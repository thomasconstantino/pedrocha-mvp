---
import Base from '../layouts/Base.astro';
import {
  totalProjetos,
  totalAlertas,
  horasPoupadasSemana,
  poupanca,
  percentagemCaptura,
  faturasCapturadas,
  totalFaturas,
  valorFaturasCapturado,
  alertas,
} from '../lib/dados';
import { eur, horas } from '../lib/formato';
import { url } from '../lib/url';

const kpis = [
  {
    label: 'Imóveis em renovação',
    valor: `${totalProjetos}`,
    nota: 'projetos ativos · 100% visíveis',
    cor: 'text-terra-700',
    href: '/imoveis',
  },
  {
    label: 'Alertas de aquisição',
    valor: `${totalAlertas}`,
    nota: 'imóveis que cumprem os critérios',
    cor: 'text-azul-700',
    href: '/alertas',
    id: 'kpi-alertas',
  },
  {
    label: 'Tempo poupado / semana',
    valor: horas(horasPoupadasSemana),
    nota: '≥ 5 h devolvidas ao Pedro',
    cor: 'text-green-700',
    href: '#tempo',
  },
  {
    label: 'Faturas capturadas',
    valor: `${percentagemCaptura}%`,
    nota: `${faturasCapturadas} / ${totalFaturas} faturas · ${eur(valorFaturasCapturado)}`,
    cor: 'text-terra-700',
    href: '/centros-custo',
  },
];
---

<Base titulo="Visão Geral" subtitulo="Estado operacional da operação imobiliária PedroCha — Vidigueira / Beja.">
  <!-- KPIs -->
  <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    {kpis.map((k) => (
      <a href={url(k.href)} class="block bg-white rounded-xl border border-terra-100 p-5 hover:shadow-md transition">
        <div class="text-xs font-medium text-gray-500 uppercase tracking-wide">{k.label}</div>
        <div id={k.id} class={`text-3xl font-bold mt-2 ${k.cor}`}>{k.valor}</div>
        <div class="text-xs text-gray-500 mt-2">{k.nota}</div>
      </a>
    ))}
  </section>

  <!-- Tempo poupado -->
  <section id="tempo" class="bg-white rounded-xl border border-terra-100 p-6 mb-8">
    <div class="flex items-baseline justify-between flex-wrap gap-2">
      <div>
        <h2 class="text-lg font-bold text-gray-900">{poupanca.titulo}</h2>
        <p class="text-sm text-gray-500 mt-0.5">{poupanca.descricao}</p>
      </div>
      <div class="text-right">
        <div class="text-3xl font-bold text-green-700">{horas(horasPoupadasSemana)}</div>
        <div class="text-xs text-gray-500">por semana</div>
      </div>
    </div>
    <div class="mt-5 space-y-3">
      {poupanca.itens.map((item) => {
        const pct = Math.round((item.horas_semana / horasPoupadasSemana) * 100);
        return (
          <div>
            <div class="flex justify-between text-sm">
              <span class="font-medium text-gray-800">{item.tarefa}</span>
              <span class="text-gray-600">{horas(item.horas_semana)}</span>
            </div>
            <div class="text-xs text-gray-500 mt-0.5">{item.antes} → <span class="text-green-700">{item.agora}</span></div>
            <div class="mt-1.5 h-1.5 bg-terra-50 rounded-full overflow-hidden">
              <div class="h-full bg-green-500 rounded-full" style={`width:${pct}%`}></div>
            </div>
          </div>
        );
      })}
    </div>
    <div class="mt-4 pt-4 border-t border-terra-100 text-sm text-gray-600">
      Total itemizado: <span class="font-bold text-green-700">{horas(horasPoupadasSemana)}/semana</span> — acima do objetivo de 5 horas.
    </div>
  </section>

  <!-- Alertas em destaque -->
  <section class="bg-white rounded-xl border border-terra-100 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold text-gray-900">Alertas de aquisição recentes</h2>
      <a href={url('/alertas')} class="text-sm text-azul-700 hover:underline">Ver todos (<span id="ver-todos-count">{totalAlertas}</span>) →</a>
    </div>
    <div id="destaque-alertas" class="divide-y divide-terra-50">
      {alertas.slice(0, 5).map((a) => (
        <div class="py-3 flex items-center justify-between gap-4">
          <div class="min-w-0">
            <div class="font-medium text-gray-900 truncate">{a.imovel.titulo}</div>
            <div class="text-xs text-gray-500">{a.imovel.localidade}, {a.imovel.concelho}</div>
          </div>
          <div class="text-right shrink-0">
            <div class="font-bold text-terra-700">{eur(a.imovel.preco_eur)}</div>
            <div class="text-xs text-gray-500">{eur(a.imovel.preco_por_m2)}/m²</div>
          </div>
        </div>
      ))}
      {alertas.length === 0 && <p class="py-3 text-sm text-gray-500">Sem alertas no momento.</p>}
    </div>
  </section>
</Base>

<script>
  import imoveisData from '../data/imoveis.json';
  import { avaliarTodos } from '../lib/alertas';
  import { getRegras } from '../lib/criteriosStore';
  import { renderDestaqueRow } from '../lib/render';
  import type { Imovel } from '../lib/tipos';

  const imoveis = imoveisData as Imovel[];
  const alertas = avaliarTodos(imoveis, { regras: getRegras() } as any).filter((a) => a.alerta);

  const kpi = document.getElementById('kpi-alertas');
  if (kpi) kpi.textContent = String(alertas.length);
  const verTodos = document.getElementById('ver-todos-count');
  if (verTodos) verTodos.textContent = String(alertas.length);

  const destaque = document.getElementById('destaque-alertas');
  if (destaque) {
    destaque.innerHTML = alertas.length
      ? alertas.slice(0, 5).map(renderDestaqueRow).join('')
      : '<p class="py-3 text-sm text-gray-500">Sem alertas no momento.</p>';
  }
</script>
