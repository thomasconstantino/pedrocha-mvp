---
import Base from '../layouts/Base.astro';
import { criterios, totalAlertas, totalImoveis } from '../lib/dados';
import { eur } from '../lib/formato';
const r = criterios.regras;

const campos = [
  { label: 'Preço máximo', valor: eur(r.preco_max_eur) },
  { label: 'Preço por m² máximo', valor: `${eur(r.preco_por_m2_max_eur)}/m²` },
  { label: 'Área mínima', valor: `${r.area_min_m2} m²` },
];
---

<Base titulo="Critérios de Aquisição" subtitulo={criterios.nome}>
  <p class="text-sm text-gray-600 mb-6 max-w-2xl">{criterios.descricao}</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl border border-terra-100 p-6">
      <h2 class="font-bold text-gray-900 mb-4">Limites numéricos</h2>
      <dl class="space-y-3">
        {campos.map((c) => (
          <div class="flex items-center justify-between border-b border-terra-50 pb-2">
            <dt class="text-sm text-gray-600">{c.label}</dt>
            <dd class="font-semibold text-terra-700">{c.valor}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="bg-white rounded-xl border border-terra-100 p-6">
      <h2 class="font-bold text-gray-900 mb-4">Filtros de elegibilidade</h2>
      <div class="mb-4">
        <div class="text-sm text-gray-600 mb-2">Concelhos-alvo</div>
        <div class="flex flex-wrap gap-2">
          {r.concelhos_alvo.map((c) => (
            <span class="px-3 py-1 rounded-full bg-terra-100 text-terra-700 text-xs">{c}</span>
          ))}
        </div>
      </div>
      <div>
        <div class="text-sm text-gray-600 mb-2">Tipos-alvo</div>
        <div class="flex flex-wrap gap-2">
          {r.tipos_alvo.map((t) => (
            <span class="px-3 py-1 rounded-full bg-azul-700/10 text-azul-700 text-xs">{t}</span>
          ))}
        </div>
      </div>
    </div>
  </div>

  <div class="mt-6 bg-white rounded-xl border border-terra-100 p-6">
    <div class="flex items-center justify-between flex-wrap gap-4">
      <div>
        <h2 class="font-bold text-gray-900">Resultado dos critérios</h2>
        <p class="text-sm text-gray-500">Aplicados a {totalImoveis} anúncios monitorizados na região (oportunidades de aquisição).</p>
      </div>
      <div class="text-right">
        <div class="text-3xl font-bold text-azul-700">{totalAlertas}</div>
        <div class="text-xs text-gray-500">alertas gerados</div>
      </div>
    </div>
    <p class="text-xs text-gray-400 mt-4">{criterios.notas}</p>
    <p class="text-xs text-gray-400 mt-1">Atualizado em {criterios.atualizado}. O motor de alertas é testado automaticamente (bun test).</p>
  </div>
</Base>
