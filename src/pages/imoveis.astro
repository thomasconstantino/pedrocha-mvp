---
import Base from '../layouts/Base.astro';
import { projetos, gastoProjeto, progressoProjeto, totalProjetos } from '../lib/dados';
import { eur, eur2, m2, dataPT } from '../lib/formato';
import { url } from '../lib/url';

const estadoFase: Record<string, { label: string; dot: string; text: string }> = {
  concluida: { label: 'Concluída', dot: 'bg-lumo-600', text: 'text-lumo-700' },
  em_curso: { label: 'Em curso', dot: 'bg-lime-400 ring-4 ring-lime-200', text: 'text-lumo-800 font-semibold' },
  planeada: { label: 'Planeada', dot: 'bg-lumo-200', text: 'text-lumo-400' },
};
---

<Base titulo="Imóveis em Renovação" subtitulo={`${totalProjetos} projetos ativos · cada casa com orçamento, custo incorrido e cronograma de obra`}>
  <div class="space-y-8">
    {projetos.map((p) => {
      const gasto = gastoProjeto(p);
      const pctOrc = Math.min(100, Math.round((gasto / p.orcamento_eur) * 100));
      const pctObra = progressoProjeto(p);
      return (
        <article class="bg-white rounded-2xl border border-lumo-100 overflow-hidden">
          <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr]">
            <!-- Foto da casa -->
            <div class="relative h-56 lg:h-full min-h-[200px] bg-lumo-100">
              <img src={url(p.imagem)} alt={p.titulo} loading="lazy" class="absolute inset-0 w-full h-full object-cover" />
              <span class="absolute top-3 left-3 px-2.5 py-1 rounded-full bg-lumo-700 text-lime-300 text-xs font-medium">{p.estado}</span>
            </div>

            <!-- Detalhe -->
            <div class="p-5 md:p-6">
              <div class="flex items-start justify-between gap-4 flex-wrap">
                <div>
                  <div class="text-xs text-lumo-500">{p.id} · {p.localidade}, {p.concelho}</div>
                  <h2 class="text-xl font-bold text-lumo-900 mt-0.5">{p.titulo}</h2>
                  <div class="text-sm text-lumo-600 mt-0.5">{p.tipologia} · {m2(p.area_m2)}</div>
                </div>
                <div class="text-right">
                  <div class="text-3xl font-bold text-lumo-700">{pctObra}%</div>
                  <div class="text-xs text-lumo-500">progresso da obra</div>
                </div>
              </div>

              <!-- Orçamento vs custo -->
              <div class="mt-5 grid grid-cols-2 gap-4">
                <div class="rounded-xl bg-cream border border-lumo-100 p-4">
                  <div class="text-xs text-lumo-500">Orçamento</div>
                  <div class="text-xl font-bold text-lumo-900 mt-0.5">{eur(p.orcamento_eur)}</div>
                </div>
                <div class="rounded-xl bg-cream border border-lumo-100 p-4">
                  <div class="text-xs text-lumo-500">Custo já incorrido</div>
                  <div class="text-xl font-bold text-lumo-700 mt-0.5">{eur2(gasto)}</div>
                </div>
              </div>
              <div class="mt-3">
                <div class="flex justify-between text-xs text-lumo-600 mb-1">
                  <span>{pctOrc}% do orçamento utilizado</span>
                  <a href={url('/centros-custo')} class="text-lumo-700 font-medium hover:underline">ver custos & faturas →</a>
                </div>
                <div class="h-2 bg-lumo-100 rounded-full overflow-hidden">
                  <div class="h-full bg-lumo-600 rounded-full" style={`width:${pctOrc}%`}></div>
                </div>
              </div>

              <!-- Cronograma / fases -->
              <div class="mt-6">
                <div class="text-xs font-semibold uppercase tracking-wide text-lumo-500 mb-3">Cronograma da obra</div>
                <ol class="relative border-l-2 border-lumo-100 ml-1.5 space-y-4">
                  {p.fases.map((f) => {
                    const s = estadoFase[f.estado];
                    return (
                      <li class="ml-5">
                        <span class={`absolute -left-[7px] mt-1 w-3 h-3 rounded-full ${s.dot}`}></span>
                        <div class="flex items-center justify-between gap-3 flex-wrap">
                          <span class={`text-sm ${s.text}`}>{f.nome}</span>
                          <span class="flex items-center gap-2 text-xs text-lumo-500">
                            {f.data && <span>{dataPT(f.data)}</span>}
                            <span class={`px-2 py-0.5 rounded-full text-[11px] ${
                              f.estado === 'concluida' ? 'bg-lime-200 text-lumo-800'
                              : f.estado === 'em_curso' ? 'bg-lime-300 text-lumo-800'
                              : 'bg-lumo-50 text-lumo-400'
                            }`}>{s.label}</span>
                          </span>
                        </div>
                      </li>
                    );
                  })}
                </ol>
              </div>
            </div>
          </div>
        </article>
      );
    })}
  </div>
</Base>
