---
import Base from '../layouts/Base.astro';
import { alertas, criterios, totalAlertas } from '../lib/dados';
import { eur, m2 } from '../lib/formato';
import { url } from '../lib/url';
const r = criterios.regras;
---

<Base titulo="Alertas de Aquisição" subtitulo={`${totalAlertas} imóveis cumprem os critérios configurados`}>
  <div class="bg-azul-700 text-white rounded-xl p-5 mb-6">
    <div class="text-sm font-medium opacity-90">Critérios ativos</div>
    <div id="chips-criterios" class="mt-2 flex flex-wrap gap-2 text-xs">
      <span class="bg-white/15 rounded-full px-3 py-1">Preço ≤ {eur(r.preco_max_eur)}</span>
      <span class="bg-white/15 rounded-full px-3 py-1">≤ {eur(r.preco_por_m2_max_eur)}/m²</span>
      <span class="bg-white/15 rounded-full px-3 py-1">Área ≥ {r.area_min_m2} m²</span>
      <span class="bg-white/15 rounded-full px-3 py-1">Concelhos: {r.concelhos_alvo.join(', ')}</span>
      <span class="bg-white/15 rounded-full px-3 py-1">Tipos: {r.tipos_alvo.join(', ')}</span>
    </div>
    <a href={url('/criterios')} class="inline-block mt-3 text-xs underline opacity-90">Configurar critérios →</a>
  </div>

  <p id="contagem-alertas" class="text-sm text-lumo-600 mb-3"></p>

  <div id="lista-alertas" class="space-y-4">
    {alertas.map((a) => (
      <div class="bg-white rounded-xl border border-terra-100 p-5">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="min-w-0">
            <div class="flex items-center gap-2">
              <span class="px-2 py-0.5 rounded-full bg-azul-700 text-white text-[10px]">Alerta de aquisição</span>
              <span class="text-xs text-gray-500">{a.imovel.id}</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mt-1">{a.imovel.titulo}</h3>
            <div class="text-sm text-gray-500">{a.imovel.localidade}, {a.imovel.concelho} · {a.imovel.tipologia}</div>
          </div>
          <div class="text-right shrink-0">
            <div class="text-xl font-bold text-terra-700">{eur(a.imovel.preco_eur)}</div>
            <div class="text-xs text-gray-500">{eur(a.imovel.preco_por_m2)}/m² · {m2(a.imovel.area_m2)}</div>
          </div>
        </div>
        <div class="mt-4 grid grid-cols-2 sm:grid-cols-5 gap-2">
          {a.razoes.map((razao) => (
            <div class={`rounded-lg px-3 py-2 text-xs ${razao.cumpre ? 'bg-green-50 text-green-800' : 'bg-red-50 text-red-700'}`}>
              <div class="font-semibold flex items-center gap-1">
                <span>{razao.cumpre ? '✓' : '✗'}</span> {razao.criterio}
              </div>
              <div class="text-[11px] opacity-80 mt-0.5">{razao.detalhe}</div>
            </div>
          ))}
        </div>
        <div class="mt-3">
          <a href={a.imovel.url} target="_blank" rel="noopener" class="text-azul-700 hover:underline text-xs">ver anúncio original →</a>
        </div>
      </div>
    ))}
    {alertas.length === 0 && (
      <div class="bg-white rounded-xl border border-terra-100 p-6 text-gray-500">Nenhum imóvel cumpre atualmente todos os critérios.</div>
    )}
  </div>
</Base>

<script>
  import imoveisData from '../data/imoveis.json';
  import { avaliarTodos } from '../lib/alertas';
  import { getRegras, isPersonalizado } from '../lib/criteriosStore';
  import { renderAlertaCard, chipsCriterios } from '../lib/render';
  import type { Imovel } from '../lib/tipos';

  const imoveis = imoveisData as Imovel[];
  const regras = getRegras();
  const evals = avaliarTodos(imoveis, { regras } as any);
  const alertas = evals.filter((a) => a.alerta);

  const chips = document.getElementById('chips-criterios');
  if (chips) chips.innerHTML = chipsCriterios(regras);

  const lista = document.getElementById('lista-alertas');
  if (lista) {
    lista.innerHTML = alertas.length
      ? alertas.map(renderAlertaCard).join('')
      : '<div class="bg-white rounded-xl border border-terra-100 p-6 text-gray-500">Nenhum imóvel cumpre atualmente todos os critérios.</div>';
  }

  const contagem = document.getElementById('contagem-alertas');
  if (contagem) {
    contagem.textContent =
      `${alertas.length} de ${imoveis.length} imóveis cumprem os critérios` +
      (isPersonalizado() ? ' (critérios personalizados).' : '.');
  }
</script>
